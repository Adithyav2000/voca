# VOCA — Production Configuration

# --------------------------------------------------------
# 1. DOCKER NETWORKING
# --------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://voca:voca@voca-db:5432/voca
REDIS_URL=redis://voca-redis:6379/0

# --------------------------------------------------------
# 2. TWILIO
# --------------------------------------------------------
TWILIO_ACCOUNT_SID=       # Paste actual SID
TWILIO_AUTH_TOKEN=        # Paste actual Token
TWILIO_PHONE_NUMBER=      # Your purchased Twilio number

# --------------------------------------------------------
# 3. OPENAI (Voice + Conversation)
# --------------------------------------------------------
OPENAI_API_KEY=           # Paste your OpenAI API Key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# --------------------------------------------------------
# 3b. PUBLIC URL (for Twilio callbacks — ngrok/cloudflare tunnel)
# --------------------------------------------------------
PUBLIC_API_URL=           # e.g. https://abc123.ngrok-free.app

# --------------------------------------------------------
# 4. GOOGLE
# --------------------------------------------------------
# Google Maps Platform
# GOOGLE_API_KEY=your_restricted_api_key_here

# Google OAuth2 (Multi-User Calendar Access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

GOOGLE_API_KEY=

NGROK_AUTHTOKEN=

# --------------------------------------------------------
# 7. FRONTEND (SPA)
# --------------------------------------------------------
# After Google login, redirect here. Also used for CORS.
FRONTEND_ORIGIN=http://localhost:5173
# OAuth callback must hit the FRONTEND URL so the session cookie is set for 5173 (otherwise cookie is for 8000 and won't be sent from the app).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/callback
SESSION_COOKIE_SECURE=False
